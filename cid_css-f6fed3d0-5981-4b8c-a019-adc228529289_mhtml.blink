ef-filing-status .btn.btn-primary-new { position: relative; min-width: 160px; display: inline-block; background-repeat: no-repeat; background-color: rgb(71, 176, 63); border: none; border-radius: 10px; font-family: PSLKandaExtraPro; font-size: 26px; line-height: 31px; text-align: center; color: rgb(255, 255, 255); letter-spacing: 1px; }

ef-filing-status .tableFooter { font-family: Sarabun; font-style: normal; font-weight: 600; font-size: 16px; line-height: 21px; display: flex; -webkit-box-align: center; align-items: center; color: rgb(120, 120, 120); padding: 0px; }

ef-filing-status .form-status .ant-table-footer { margin-top: 11px; position: relative; padding: 0px; background: rgb(250, 250, 250); border-top: none; }

ef-filing-status .form-status .ant-table-footer::before { content: none; }

ef-filing-status .form-status .ant-table-footer .tableFooters { background-color: rgb(255, 255, 255); font-family: Sarabun; font-style: normal; font-weight: 600; font-size: 16px; line-height: 21px; display: flex; -webkit-box-align: center; align-items: center; color: rgb(71, 176, 63); padding: 0px; }

