@charset "utf-8";

.container-boby[_ngcontent-knm-c84] { position: relative; width: 100%; padding-right: 128px; padding-left: 128px; }

.button-person[_ngcontent-knm-c84] { font-family: "PSL KandaExtra Pro"; font-size: 28px; border: none; outline-style: none; -webkit-box-align: center; align-items: center; position: relative; background: rgb(247, 247, 247); color: rgb(120, 120, 120); line-height: 34px; margin-bottom: 34px; padding: 0px 0px 6px; }

.button-person-active[_ngcontent-knm-c84] { padding: 0px 0px 4px; color: rgb(28, 28, 28); border-bottom: 2px solid rgb(71, 176, 63); }

.person[_ngcontent-knm-c84] { position: relative; border: 0px; padding: 0px 6px 6px; outline-style: none; }

.font-p[_ngcontent-knm-c84] { font-family: "PSL KandaExtra Pro"; font-style: normal; font-weight: 800; font-size: 40px; line-height: 35px; color: rgb(28, 28, 28); margin-bottom: 23px; }

ef-filing-status .card { position: relative; display: flex; -webkit-box-orient: vertical; -webkit-box-direction: normal; flex-direction: column; min-width: 0px; overflow-wrap: break-word; background-color: rgb(255, 255, 255); background-clip: border-box; border: 1px solid rgba(0, 0, 0, 0.125); border-radius: 10px; }

ef-filing-status .card-body-status { -webkit-box-flex: 1; flex: 1 1 auto; min-height: 1px; padding: 1.25rem; }

ef-filing-status .font-p { font-family: "PSL KandaExtra Pro"; font-style: normal; font-weight: 800; font-size: 30px; line-height: 36px; color: rgb(71, 176, 63); padding-left: 0px; }

ef-filing-status .head-line { border-bottom: 1px solid rgb(232, 232, 232); padding-bottom: 10px; margin: 0px 20px; }

ef-filing-status .align-items-center { -webkit-box-align: center !important; align-items: center !important; }

ef-filing-status .m-search { margin-top: 13px; }

ef-filing-status .p-search { padding-left: 20px; padding-right: 20px; }

ef-filing-status .p-search .form-control::-webkit-input-placeholder { font-size: 12px; line-height: 2em; }

ef-filing-status .box-search { }

ef-filing-status .input-search { height: 40px; border: 1px solid rgb(226, 226, 226); box-sizing: border-box; border-radius: 10px; }

ef-filing-status typeahead-container.dropdown { background: rgb(255, 255, 255) !important; }

ef-filing-status .collapsed { position: absolute; right: 15px; top: 0px; padding: 8px 10px; cursor: pointer; color: rgb(81, 184, 104); font-size: 18px; font-family: "PSL KandaExtra Pro"; }

ef-filing-status .collapsed .fa-angle-down { color: rgb(81, 184, 104); position: relative; top: 3px; }

ef-filing-status .collapsed .fa-angle-up { color: rgb(81, 184, 104); position: relative; top: 3px; }

ef-filing-status .search { position: absolute; padding: 0px; margin-top: 12.25px; margin-left: 20.25px; margin-right: 13.25px; color: rgb(176, 176, 176); }

ef-filing-status .input-search-font { font-family: Sarabun; font-style: normal; font-weight: 300; font-size: 18px; line-height: 23px; display: flex; -webkit-box-align: center; align-items: center; text-align: left; color: rgb(176, 176, 176); padding: 4px 120px 8px 45px; }

ef-filing-status .box-collapseExample { padding-left: 20px; padding-right: 20px; }

ef-filing-status .box-collapseExample .ng-dropdown-panel .ng-dropdown-panel-items { max-height: 300px; }

ef-filing-status .button-form-group { background: rgb(255, 255, 255); border: 1px solid rgb(226, 226, 226); box-sizing: border-box; border-radius: 10px; }

ef-filing-status .m-box { margin-top: 7px; }

ef-filing-status .m-box-font { font-family: Sarabun; font-style: normal; font-weight: 300; font-size: 16px; line-height: 21px; display: flex; -webkit-box-align: center; align-items: center; color: rgb(120, 120, 120); }

ef-filing-status .form-group { margin-bottom: 21px; }

ef-filing-status .form-group .font-filing-status .ng-select.ng-select-single .ng-select-container .ng-value-container .ng-value { font-size: 11px; }

ef-filing-status .input-advanced-search .ng-select .ng-select-container, ef-filing-status .input-advanced-search .ng-select.ng-select-focused:not(.ng-select-opened) > .ng-select-container { background: rgb(255, 255, 255); border-radius: 10px; height: 35px; border: 1px solid rgb(226, 226, 226) !important; }

ef-filing-status .input-advanced-search .form-control { background: rgb(255, 255, 255); border: 1px solid rgb(226, 226, 226); border-radius: 10px; height: 35px; font-size: 16px; line-height: 19px; }

ef-filing-status .input-advanced-search input[bsdatepicker].form-control { padding-right: 30px; background-image: url("icon-calendar-new.79f8d39361a016fbd348.svg") !important; background-size: 18px 18px !important; background-position: right 10px center !important; background-repeat: no-repeat !important; appearance: none !important; }

ef-filing-status .ng-select { border-radius: 10px; color: rgb(112, 111, 114); font-size: 16px; line-height: 19px; background: rgb(255, 255, 255); }

ef-filing-status .button-box { font-family: "PSL KandaExtra Pro"; font-style: normal; font-weight: 800; font-size: 26px; line-height: 31px; text-align: center; display: inline-block; border-radius: 10px; width: 160px; height: 40px; border: none; }

ef-filing-status .button-box-clean { color: rgb(120, 120, 120); background-color: rgb(226, 226, 226); }

ef-filing-status .button-box-search { color: rgb(255, 255, 255); background-color: rgb(71, 176, 63); }

ef-filing-status .button-box-search:hover { color: rgb(255, 255, 255); background-color: rgb(72, 190, 63); }

ef-filing-status .button-box-search:active { color: rgb(255, 255, 255); background-color: rgb(71, 176, 63); }

