ef-filing-status .popover { background-color: rgb(232, 255, 229); border-color: rgb(71, 176, 63); width: max-content; }

ef-filing-status .popover.top > .arrow { border-top-color: rgb(71, 176, 63); }

ef-filing-status .popover.top > .arrow::before { border-top-color: rgb(71, 176, 63); }

ef-filing-status .popover.top > .arrow::after { border-top-color: rgb(232, 255, 229); }

ef-filing-status .popover.left > .arrow { border-left-color: rgb(71, 176, 63); }

ef-filing-status .popover.left > .arrow::before { border-left-color: rgb(71, 176, 63); }

ef-filing-status .popover.left > .arrow::after { border-left-color: rgb(232, 255, 229); }

ef-filing-status .popover.right > .arrow { border-right-color: rgb(71, 176, 63); }

ef-filing-status .popover.right > .arrow::before { border-right-color: rgb(71, 176, 63); }

ef-filing-status .popover.right > .arrow::after { border-right-color: rgb(232, 255, 229); }

ef-filing-status .popover.bottom > .arrow { border-bottom-color: rgb(71, 176, 63); }

ef-filing-status .popover.bottom > .arrow::before { border-bottom-color: rgb(71, 176, 63); }

ef-filing-status .popover.bottom > .arrow::after { border-bottom-color: rgb(232, 255, 229); }

.modal-filing-status { border: none; }

.modal-filing-status .modal-header { padding: 8px 30px; border-bottom: 0px; position: relative; }

.modal-filing-status .modal-header::after { content: ""; width: calc(100% - 60px); height: 1px; background-color: rgb(232, 232, 232); display: inline-block; position: absolute; left: 30px; bottom: 0px; }

.modal-filing-status .modal-header .modal-title { font-family: "PSL KandaExtra Pro"; font-weight: 800; font-size: 30px; line-height: 36px; color: rgb(71, 176, 63); }

.modal-filing-status .modal-body span.required { color: rgb(245, 77, 65); }

.modal-filing-status .modal-body .form-inline label { width: 100%; display: block; }

.modal-filing-status .modal-body .form-group { margin-bottom: 1rem; }

.modal-filing-status .modal-body .form-control, .modal-filing-status .modal-body label { font-family: Sarabun; font-weight: 300; font-size: 16px; color: rgb(120, 120, 120); }

.modal-filing-status .modal-body .form-control { width: 100%; height: 40px; border-radius: 10px; box-shadow: none; color: rgb(28, 28, 28); border: 1px solid rgb(226, 226, 226) !important; }

.modal-filing-status .modal-footer { border-top: 0px; }

.modal-filing-status .close { outline: 0px; }

.modal-filing-status .modal-content { position: relative; display: flex; -webkit-box-orient: vertical; -webkit-box-direction: normal; flex-direction: column; width: 100%; pointer-events: auto; background-color: rgb(255, 255, 255); background-clip: padding-box; border: 1px solid rgba(0, 0, 0, 0.2); border-radius: 10px; outline: 0px; }

.modal-filing-status .modal-content .btn { border-radius: 10px; min-width: 150px; border: none; font-size: 16px; }

.modal-filing-status .modal-font p { font-family: SarabunLight; font-size: 20px; line-height: 26px; font-weight: 300; }

.modal-filing-status .modal-font .btn { min-width: 160px; height: 40px; margin-left: 15px; display: inline-block; position: relative; border-radius: 10px; vertical-align: top; font-family: PSLKandaExtraPro; font-size: 26px; line-height: 24px; text-align: center; letter-spacing: 1px; }

.modal-filing-status .modal-font .btn.btn-primary-new { background-color: rgb(71, 176, 63); border: 1px solid rgb(71, 176, 63); color: rgb(255, 255, 255); }

.modal-filing-status .modal-font .btn.btn-primary-new:hover { background-color: rgb(60, 150, 54); }

.modal-filing-status .modal-font .btn.btn-primary-new:active { background-color: rgb(50, 123, 44); }

.modal-filing-status .modal-font .btn.btn-default-new { background-color: rgb(226, 226, 226); border: 1px solid rgb(226, 226, 226); color: rgb(120, 120, 120); }

.modal-filing-status .modal-font .btn.btn-default-new:active, .modal-filing-status .modal-font .btn.btn-default-new:hover { background-color: rgb(210, 210, 210); }

.modal-download .ng-placeholder { width: 100%; text-align: center; }

.modal-download .ng-value { width: 100%; }