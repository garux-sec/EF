ef-filing-status .td-action button.od-FieldRenderer-dot { padding: 6px 13px; border: 1px solid rgb(71, 176, 63); border-radius: 10px; color: rgb(71, 176, 63); display: inline-block; outline: 0px; }

ef-filing-status .td-action button.od-FieldRenderer-dot:active, ef-filing-status .td-action button.od-FieldRenderer-dot:hover { background-color: rgba(71, 176, 63, 0.3); }

ef-filing-status .td-action .dropdown-menu.show { margin-top: 5px; margin-left: 10px; margin-right: 10px; width: auto; min-width: 40px; position: relative; display: inline-block; float: none; border-radius: 10px; overflow: hidden; right: 0px !important; }

ef-filing-status .td-action .dropdown-menu.show.dd-action-pay { transform: translateX(20px) !important; }

ef-filing-status .td-action .dropdown-menu.show > li { border-bottom: 1px solid rgb(232, 232, 232); }

ef-filing-status .td-action .dropdown-menu.show > li:last-child { border-bottom: none; }

ef-filing-status .td-action .dropdown-menu.show > li > a { height: 40px; font-family: "PSL KandaExtra Pro"; font-weight: 800; font-size: 26px; line-height: 22px; text-align: center; color: rgb(71, 176, 63); }

ef-filing-status .td-action .dropdown-menu.show > li > a.disabled { pointer-events: none !important; opacity: 0.6 !important; }

ef-filing-status .ant-pagination-total-text { position: absolute; font-family: Sarabun; font-style: normal; font-weight: 300; font-size: 16px; color: rgb(120, 120, 120); left: 0px; width: 50%; display: inline-block; height: 32px; margin-right: 8px; line-height: 30px; vertical-align: middle; }

ef-filing-status .footer-remark { font-family: Sarabun; font-weight: 600; font-size: 17px; line-height: 22px; }

ef-filing-status .footer-remark ol, ef-filing-status .footer-remark ul { padding-left: 17px; line-height: 28px; color: rgb(71, 176, 63); }

