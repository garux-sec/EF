.icon-progress[_ngcontent-knm-c16] i[_ngcontent-knm-c16] { font-size: 32px; }

.icon-progress[_ngcontent-knm-c16] { margin-bottom: 0px; }

.card-header.bg-transparent.border-bottom-0.pb-4.pt-4[_ngcontent-knm-c16] { margin: 0px 0px -30px; }