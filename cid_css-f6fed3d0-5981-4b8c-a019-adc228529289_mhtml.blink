ef-filing-status .button-box-close-modal:active { color: rgb(255, 255, 255); background-color: rgb(71, 176, 63); }

ef-filing-status .button-box-clean-dowload { color: rgb(71, 176, 63); background-color: rgb(255, 255, 255); border: 1px solid rgb(71, 176, 63); }

ef-filing-status .button-box-clean-dowload:disabled { background-color: rgb(226, 226, 226); color: rgb(120, 120, 120); border-color: rgb(226, 226, 226); }

ef-filing-status .button-box-clean-dowload:active, ef-filing-status .button-box-clean-dowload:hover { color: rgb(71, 176, 63); background-color: rgba(71, 176, 63, 0.3); }

